{
  "manifest_version": 3,
  "name": "ScanCart",
  "version": "0.2.0",
  "description": "Real-time shopping intelligence for product pages across major retailers.",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.target.com/*",
    "https://*.instacart.com/*",
    "https://*.walmart.com/*",
    "https://*.wholefoodsmarket.com/*",
    "https://*.sephora.com/*",
    "https://*.costco.com/*",
    "https://*.ebay.com/*",
    "https://*.etsy.com/*",
    "https://*.bestbuy.com/*",
    "https://*.cvs.com/*",
    "https://*.walgreens.com/*",
    "https://*.kroger.com/*",
    "https://*.samsclub.com/*",
    "https://*.aldi.us/*",
    "https://*.traderjoes.com/*",
    "https://*.freshdirect.com/*",
    "https://*.shipt.com/*",
    "https://*.hungryroot.com/*",
    "https://*.misfitsmarket.com/*",
    "https://world.openfoodfacts.org/*",
    "https://world.openbeautyfacts.org/*",
    "https://api.nal.usda.gov/*",
    "https://api.ods.od.nih.gov/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "ScanCart"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.target.com/*",
        "https://*.instacart.com/*",
        "https://*.walmart.com/*",
        "https://*.wholefoodsmarket.com/*",
        "https://*.sephora.com/*",
        "https://*.costco.com/*",
        "https://*.ebay.com/*",
        "https://*.etsy.com/*",
        "https://*.bestbuy.com/*",
        "https://*.cvs.com/*",
        "https://*.walgreens.com/*",
        "https://*.kroger.com/*",
        "https://*.samsclub.com/*",
        "https://*.aldi.us/*",
        "https://*.traderjoes.com/*",
        "https://*.freshdirect.com/*",
        "https://*.shipt.com/*",
        "https://*.hungryroot.com/*",
        "https://*.misfitsmarket.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "extractors/*"
      ],
      "matches": [
        "https://*.amazon.com/*",
        "https://*.target.com/*",
        "https://*.instacart.com/*",
        "https://*.walmart.com/*",
        "https://*.wholefoodsmarket.com/*",
        "https://*.sephora.com/*",
        "https://*.costco.com/*",
        "https://*.ebay.com/*",
        "https://*.etsy.com/*",
        "https://*.bestbuy.com/*",
        "https://*.cvs.com/*",
        "https://*.walgreens.com/*",
        "https://*.kroger.com/*",
        "https://*.samsclub.com/*",
        "https://*.aldi.us/*",
        "https://*.traderjoes.com/*",
        "https://*.freshdirect.com/*",
        "https://*.shipt.com/*",
        "https://*.hungryroot.com/*",
        "https://*.misfitsmarket.com/*"
      ]
    }
  ]
}
